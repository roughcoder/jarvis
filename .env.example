# Jarvis Phase 1 config — copy to .env and fill in secrets.
# HARD RULE (spec §3.1): all hosts/ports are env-driven; defaults are localhost.
# Phase 2 migration = change the *_HOST vars to a Tailscale hostname. Nothing else.

# --- LLM gateway (LiteLLM proxy) -----------------------------------------
GATEWAY_HOST=localhost
GATEWAY_PORT=4000
GATEWAY_API_KEY=
GATEWAY_CLIENT_KEY=
GATEWAY_SPEAKER=family
GATEWAY_ROOM=default
GATEWAY_FAST_MODEL=fast
GATEWAY_VOICE_MODEL=strong          # spoken turns only; set to fast to minimise cost/latency
GATEWAY_STRONG_MODEL=strong
GATEWAY_EMBED_MODEL=embed            # LiteLLM embeddings route (only for TOOLS_RELEVANCE_MODE=embedding)
GATEWAY_VISION_MODEL=strong          # route used once an image enters a turn (look_at_screen); MUST be vision-capable (e.g. gpt-4o)
GATEWAY_STREAM=true

# Provider keys consumed by LiteLLM (NOT by the turn loop). At least one.
ANTHROPIC_API_KEY=
# Remote (cloud) coding lane — Managed Agents. Run `jarvis remote-setup` to
# create these once; or set them by hand. ANTHROPIC_API_KEY above is reused.
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENVIRONMENT_ID=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HONCHO_LLM_KEY=

# --- Memory (Honcho) ------------------------------------------------------
MEMORY_HOST=localhost
MEMORY_PORT=8000
MEMORY_BACKEND=v2
MEMORY_API_KEY=
MEMORY_WORKSPACE_ID=jarvis
MEMORY_USER_PEER_ID=user
MEMORY_ASSISTANT_PEER_ID=jarvis
MEMORY_CACHE_PATH=.cache/representation.json
MEMORY_CONCLUSION_SIDECAR_PATH=jarvis-workspace/memory/conclusions-v3-sidecar.json
MEMORY_CURATION_OUTBOX_PATH=jarvis-workspace/memory/curation-outbox.jsonl
MEMORY_CURATION_OUTBOX_MAX_RETRIES=3
MEMORY_CURATION_OUTBOX_BACKOFF_INITIAL_S=0.25
MEMORY_CURATION_OUTBOX_BACKOFF_MAX_S=2
MEMORY_TOOL_TIMEOUT_S=5
MEMORY_REFRESH_INTERVAL_S=30
MEMORY_DERIVER_IDLE_TIMEOUT_S=3
# Dev/staging default used by `jarvis memory-migrate`; real cutover operators
# must pass --workspace and the exact acknowledgement flag for non-dev targets.
MEMORY_MIGRATION_WORKSPACE_ID=jarvis-migration-dev

# --- Database (Postgres + pgvector, backs Honcho) -------------------------
DB_HOST=localhost
DB_PORT=5433
DB_USER=honcho
DB_PASSWORD=honcho
DB_NAME=honcho

# --- TTS (cloud streaming) ------------------------------------------------
# provider: inworld | smallest
TTS_PROVIDER=inworld
TTS_BASE_URL=https://api.inworld.ai
TTS_API_KEY=
TTS_VOICE=Sarah
TTS_MODEL_ID=inworld-tts-2
TTS_DELIVERY_MODE=BALANCED
TTS_LANGUAGE=en-US
TTS_CONNECT_TIMEOUT_S=10
TTS_REQUEST_TIMEOUT_S=60

# --- STT (local Faster-Whisper) ------------------------------------------
STT_MODEL=small.en
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
STT_BEAM_SIZE=1

# --- VAD (Silero) — tunables (spec §8) -----------------------------------
# 700ms trailing silence ends the utterance (streaming STT overlaps this window,
# so a shorter endpoint no longer delays transcription). Raise if it cuts you off.
VAD_ENDPOINT_SILENCE_MS=700
VAD_SPEECH_THRESHOLD=0.5
VAD_BARGEIN_ENABLED=true
VAD_BARGEIN_MODE=wakeword
VAD_BARGEIN_THRESHOLD=0.6
VAD_BARGEIN_MIN_MS=200
VAD_BARGEIN_GRACE_MS=250
VAD_MIN_SPEECH_MS=200
VAD_CONVERSATION_MODE=true
VAD_CONVERSATION_TIMEOUT_MS=8000

# --- Wake word (openWakeWord "hey_jarvis" | set WAKE_ENGINE=porcupine) ----
WAKE_ENGINE=openwakeword
WAKE_ACCESS_KEY=
WAKE_KEYWORD=hey_jarvis
WAKE_THRESHOLD=0.5
WAKE_KEYWORD_PATH=
WAKE_SENSITIVITY=0.5

# --- Audio ----------------------------------------------------------------
AUDIO_SAMPLE_RATE=16000
AUDIO_FRAME_MS=32
AUDIO_ACK_MODE=beep
AUDIO_ACK_PHRASE=Yes?
# Streaming playback: per-callback block (2048 ≈ 85ms at 24k), silent warmup
# before the first audible sample, and how much REAL audio must buffer before
# speech starts (jitter absorption at the sentence onset). Both gates overlap
# the TTS time-to-first-audio, so they add ~nothing to felt latency.
AUDIO_PLAYBACK_BLOCKSIZE=2048
AUDIO_PLAYBACK_PREROLL_MS=300
AUDIO_PLAYBACK_PREBUFFER_MS=200

# --- Tracing (per-turn pipeline timings) ---------------------------------
TRACE_ENABLED=true
# Relative paths are resolved from the Jarvis env/state dir, so services and
# `jarvis traces` read the same file after reboots and from any shell cwd.
TRACE_PATH=.cache/traces.jsonl
TRACE_CONSOLE=true

# --- Persona (soul personality + shared conversation context) ------------
PERSONA_SOUL_PATH=SOUL.md
PERSONA_HISTORY_MESSAGES=16
# Tool results carried into later turns' context are truncated to this many chars
# (0 = keep full) — stops one browsed page inflating every following prompt.
PERSONA_HISTORY_TOOL_RESULT_CHARS=1500
PERSONA_EXPRESSIVE=true
# IANA tz so Jarvis knows the date/time without a search (empty = host local):
PERSONA_TIMEZONE=Europe/London

# --- Capabilities (Phase 3 §4/§5) — deny-by-default tool/identity gate ----
# This device's id (picks profiles/<device_id>.md). identity/scope are single-
# principal in 3a. With no profile file AND no default below, NOTHING is granted.
CAPS_DEVICE_ID=local-mac
CAPS_IDENTITY=house
CAPS_SCOPE=house
CAPS_PROFILES_DIR=jarvis-workspace/profiles
# Phase 3d: per-user identity bindings + grants (users/<name>.md). See the file
# format in docs/PHASE3.md §5/§10. Missing dir => house-only (single principal).
CAPS_USERS_DIR=jarvis-workspace/users
# CSV fallback used only when no profiles/<device_id>.md exists, e.g.:
# CAPS_DEFAULT_CAPABILITIES=web.search,files.read
# Memory examples:
#   search memory: memory.query
#   curate declared memory: memory.curate
#   edit user/profile files: profile.write
# Grant these here only for a single-user/default setup, or prefer
# profiles/<device_id>.md / users/<name>.md front-matter for scoped devices/users:
#   capabilities: [memory.query, memory.curate, profile.write]
# Orchestration examples:
#   read GitHub work: work.github.issues.read,work.github.pr.read
#   read Linear work: work.linear.read
#   start worker jobs: worker.job.start
CAPS_DEFAULT_CAPABILITIES=

# --- Account bindings (household email/calendar) -------------------------
# Private account binding metadata. User files reference binding names only;
# provider tokens stay in gogcli/MCP/vault state, not tracked files.
ACCOUNTS_BINDINGS_DIR=jarvis-workspace/.accounts
ACCOUNTS_AUDIT_PATH=jarvis-workspace/.accounts/audit.jsonl
ACCOUNTS_HOUSE_EMAIL_BINDING=house-email
ACCOUNTS_HOUSE_CALENDAR_BINDING=house-calendar

# --- Registry (projects + contacts; private local state) ------------------
REGISTRY_PATH=jarvis-workspace/registry/registry.json
REGISTRY_FILES_VAULT_ROOT=jarvis-workspace
REGISTRY_UPLOAD_STAGING_ROOT=jarvis-workspace/uploads/staging
REGISTRY_UPLOAD_MANIFEST_PATH=jarvis-workspace/registry/upload-manifest.json
REGISTRY_MAX_UPLOAD_BYTES=26214400
REGISTRY_UPLOAD_URL_MAX_REDIRECTS=3

# --- Tools (Phase 3 §6) — provider keys are brain-side only ---------------
TOOLS_TIMEOUT_S=8
TOOLS_MAX_ROUNDS=4
TOOLS_HEARTBEAT_INTERVAL_S=1.2     # soft pulse cadence while a web search runs
TOOLS_FILES_ROOT=jarvis-workspace/files
TOOLS_SELF_MAX_BYTES=6000          # max bytes returned by each self-diagnostic command
TOOLS_SELF_DIAGNOSTIC_TIMEOUT_S=3  # per-command timeout for fixed self diagnostics
TOOLS_LOG_CALLS=true               # console-log each tool call (name, cap, args, result)
# Relevance prefilter (§9): only OFFER MCP servers relevant to the utterance so the
# voice prompt isn't 100+ tool schemas/turn (all tools stay registered + gated).
# Built-ins always offered.
TOOLS_RELEVANCE_FILTER=true
# How relevance is scored: "keyword" (instant, default) or "embedding" (semantic,
# via GATEWAY_EMBED_MODEL; one small embed per turn, keyword fallback on error).
TOOLS_RELEVANCE_MODE=keyword
TOOLS_RELEVANCE_THRESHOLD=0.30       # min cosine similarity to include a server
# web_search: provider + key (no key => the tool reports "not configured").
TOOLS_WEBSEARCH_PROVIDER=tavily
TOOLS_WEBSEARCH_API_KEY=
TOOLS_WEBSEARCH_MAX_RESULTS=5

# --- Brain server / intercom (Phase 3 W4) --------------------------------
# `jarvis brain` serves here; `jarvis run` connects as a thin intercom.
# `jarvis run --local` runs both in one process (no server needed).
BRAIN_HOST=localhost
BRAIN_PORT=8700
BRAIN_PAIRING_TOKEN=                 # shared fallback token; empty => accept any device (dev only)
BRAIN_PEER_TOKEN=                    # distinct trusted-peer token for jarvis api / mcp-serve project writes
# Per-device pairing (Phase 3d): each device its own token, bound to its device_id
# (a leaked Pi token can't impersonate your Mac). A personal device pins `identity`;
# a shared room device leaves it empty (house until a speaker is confirmed).
# BRAIN_DEVICES=[{"token":"pi-secret","device_id":"room-pi"},{"token":"mac-secret","device_id":"local-mac","identity":"neil"}]
BRAIN_DEVICES=[]
# No-token auth is open (local dev). On a NON-loopback BRAIN_HOST the brain refuses to
# start without a token — set one above, or this to allow it anyway (unsafe).
BRAIN_ALLOW_INSECURE=false
BRAIN_WEBSOCKET_MAX_SIZE=8388608
BRAIN_WEBSOCKET_PING_INTERVAL_S=20
BRAIN_WEBSOCKET_PING_TIMEOUT_S=60
# Streaming STT: snapshot transcriptions run WHILE you speak, so the final
# transcript is usually ready inside the endpoint-silence window — hiding most of
# the ~0.7-1s Whisper cost. A snapshot is reused when only endpoint silence
# arrived after it. Snapshots self-throttle (never more than one running); costs
# extra Whisper CPU during capture — disable on constrained hosts.
BRAIN_STREAMING_STT_ENABLED=true
BRAIN_STREAMING_STT_MIN_AUDIO_S=1.0
BRAIN_STREAMING_STT_INTERVAL_S=0.5
BRAIN_STREAMING_STT_MAX_PARTIALS=8
INTERCOM_BRAIN_HOST=localhost
INTERCOM_BRAIN_PORT=8700
INTERCOM_WEBSOCKET_MAX_SIZE=8388608
INTERCOM_WEBSOCKET_PING_INTERVAL_S=20
INTERCOM_WEBSOCKET_PING_TIMEOUT_S=60
INTERCOM_WEBSOCKET_OPEN_TIMEOUT_S=10
INTERCOM_WEBSOCKET_CLOSE_TIMEOUT_S=5
INTERCOM_NETWORK_RECOVER_CMD=/usr/local/bin/jarvis-network-recover
INTERCOM_NETWORK_RECOVER_TIMEOUT_S=20
INTERCOM_NETWORK_PROBE_HOST=1.1.1.1
INTERCOM_NETWORK_PROBE_PORT=53
INTERCOM_NETWORK_PROBE_TIMEOUT_S=0.75
INTERCOM_TOKEN=                      # must match BRAIN_PAIRING_TOKEN when set
# Optional Pi-local hardware. "auto" probes the device; grant matching capability
# in profiles/<device_id>.md before the brain can use it:
#   intercom.camera  -> take_photo tool ("what am I holding?")
#   intercom.display -> PiPanel on the touch screen
INTERCOM_DEVICE_CAMERA=auto
INTERCOM_DEVICE_CAMERA_BIN=          # explicit rpicam-still/libcamera-still path; empty = probe PATH
INTERCOM_DEVICE_CAMERA_WIDTH=1280
INTERCOM_DEVICE_CAMERA_HEIGHT=720
INTERCOM_DEVICE_CAMERA_TIMEOUT_S=8
INTERCOM_DEVICE_CAMERA_WARMUP_MS=300
INTERCOM_DEVICE_PI_PANEL=auto
INTERCOM_DEVICE_PI_PANEL_SLEEP_AFTER_S=90
# Optional Tk geometry for multi-output Pi desktops; Pironman DSI is usually 800x480+0+0.
INTERCOM_DEVICE_PI_PANEL_GEOMETRY=
INTERCOM_DEVICE_PI_PANEL_SHOW_CMD="sudo jarvis-pi panel-start"
INTERCOM_DEVICE_PI_PANEL_HIDE_CMD="sudo jarvis-pi panel-stop"
INTERCOM_DEVICE_PI_PANEL_STATUS_CMD="sudo jarvis-pi panel-status"
INTERCOM_DEVICE_PI_PANEL_CONTROL_TIMEOUT_S=8
# Legacy aliases still work on existing Pi installs:
# INTERCOM_DEVICE_EYES=auto
# INTERCOM_DEVICE_EYES_SLEEP_AFTER_S=90

# --- Worker daemon (Phase 3c) — deep work + machine control --------------
# `jarvis worker` runs the daemon on the worker Mac; the brain dispatches to it.
# Provider binaries (codex/claude) are local to the worker. Gate it hard.
WORKER_HOST=localhost
WORKER_PORT=8780
WORKER_BIND_HOST=                    # daemon bind addr; empty => WORKER_HOST
WORKER_TOKEN=                        # shared auth token (empty = open, dev only)
# On a non-loopback WORKER_HOST/WORKER_BIND_HOST the worker refuses to start without a
# token (it exposes shell/GUI/browser) — set WORKER_TOKEN, or this to override (unsafe).
WORKER_ALLOW_INSECURE=false
WORKER_WORKSPACE=~/.jarvis/worker
# Request body ceiling; must fit base64-encoded turn attachments.
WORKER_MAX_REQUEST_BYTES=33554432
WORKER_AGENT=codex                  # default coding agent: codex | claude
WORKER_SUPPORTED_ENGINES=           # CSV; e.g. codex,claude. Empty = WORKER_AGENT only
WORKER_WORKTREE_STALE_TTL_S=604800  # non-live worktrees older than this are stale
# Where your git repos live, so a job can name a repo ("polymarket") not a path:
WORKER_REPO_ROOT=
WORKER_CLONE_MISSING=true            # clone a named repo via `gh` if not found
WORKER_REPO_ACCESS_PROBE_TIMEOUT_S=10
WORKER_REPO_ACCESS_TTL_S=300         # cache worker git identity/repo access probes
# How long a Claude session approval/question may wait for a human before auto-deny.
# The turn clock pauses while the request is pending. 0 = inherit WORKER_JOB_TIMEOUT_S.
WORKER_APPROVAL_TIMEOUT_S=0
# Secrets Jarvis may USE (not see) in shell commands: a comma-separated allowlist of
# env var names the worker injects into the shell env, so commands can reference e.g.
# `$OPENAI_API_KEY` by name. Deny-by-default (empty). Only list what you're OK with —
# anything with worker.shell could also print these.
WORKER_SHELL_SECRETS=
# mac-control (peekaboo, worker.gui). GUI control is agent-only: `control_mac` (act)
# + `look_at_screen` (read, native screencapture — no key). `control_mac` uses
# peekaboo's own agent, which needs an AI provider — point it at OpenAI or LiteLLM:
#   direct OpenAI: WORKER_PEEKABOO_AI_PROVIDERS=openai/gpt-4o + the OpenAI key below
#   via LiteLLM:   base_url=http://localhost:4000/v1, key=a LiteLLM key, providers=openai/<route>
WORKER_PEEKABOO_AI_PROVIDERS=
WORKER_PEEKABOO_OPENAI_BASE_URL=
WORKER_PEEKABOO_OPENAI_API_KEY=
# The model the agent uses. Must be peekaboo-supported: the OpenAI family is gpt-5.x
# (gpt-4o is NOT valid); e.g. "gpt-5.5" / "gpt-5-mini", or "openrouter/<provider>/<model>"
# (+ the OpenRouter key below) to dodge OpenAI project restrictions.
WORKER_PEEKABOO_AGENT_MODEL=gpt-5.5
WORKER_PEEKABOO_OPENROUTER_API_KEY=
WORKER_VERBOSE=true                  # worker logs each action + full peekaboo output
WORKER_DIAGNOSTICS_TTL_S=60          # cache /health readiness checks so probes stay cheap
# control_mac is one-shot, so by default the agent is told it's authorised to finish
# the task (the user asked by voice) instead of stalling on a confirmation it can't get.
# Set false to let it pause + ask — Jarvis then relays the question to you.
WORKER_PEEKABOO_AGENT_AUTONOMOUS=true

# --- Heartbeat (Phase 3b) — proactive, cold-path reach-out ----------------
# `jarvis brain` runs it when enabled. Works HEARTBEAT.md on a timer and pushes a
# Proactive message ONLY when something's worth saying (silent otherwise).
HEARTBEAT_ENABLED=false
HEARTBEAT_INTERVAL_S=900             # how often to run the checklist (15 min)
HEARTBEAT_PATH=jarvis-workspace/HEARTBEAT.md
HEARTBEAT_SENTINEL=NO_REPLY          # the "nothing worth saying" marker

# --- Background-task lane — fire-and-forget agentic work ------------------
# Jarvis kicks off a slow, multi-step task (book a table, deep research, a long
# Mac job), says "on it" instantly, runs it detached with the asker's OWN
# capabilities, and pushes the outcome as a Proactive message when done. Gated by
# the `background.run` capability (grant it in a profile/user file).
BACKGROUND_ENABLED=true
BACKGROUND_MAX_CONCURRENT=3           # reject new jobs past this many running at once
BACKGROUND_TIMEOUT_S=600              # hard ceiling per job (10 min)
BACKGROUND_MAX_ROUNDS=12              # tool-loop rounds per job (it's unattended)

# --- Agentic work orchestration ------------------------------------------
# Local source-of-truth state for runs, worker profiles, and schedules.
# Trackers such as GitHub/Linear reflect public state; Jarvis owns orchestration.
ORCHESTRATION_WORKSPACE=jarvis-workspace/orchestration
ORCHESTRATION_WORKERS_PATH=jarvis-workspace/orchestration/workers.json
ORCHESTRATION_SCHEDULES_PATH=jarvis-workspace/orchestration/schedules.json
ORCHESTRATION_DEFAULT_REPO=
ORCHESTRATION_DEFAULT_TIMEZONE=Europe/London
ORCHESTRATION_ORCHESTRATOR_MODEL=strong
# branch_only | draft_pr | ready_pr; public writes still require capabilities.
ORCHESTRATION_LANDING_MODE=draft_pr
# Cockpit API for T3-style operator UIs. `jarvis api` serves /v1 here.
ORCHESTRATION_API_HOST=localhost
ORCHESTRATION_API_PORT=8790
ORCHESTRATION_API_BIND_HOST=
ORCHESTRATION_API_TOKEN=
ORCHESTRATION_API_ALLOW_INSECURE=false
# Optional comma-separated browser origins allowed to call /v1 directly.
# Prefer a same-origin server-side cockpit proxy when possible.
ORCHESTRATION_API_CORS_ORIGINS=
# Cockpit API auth mode: legacy, oauth, or hybrid.
ORCHESTRATION_AUTH_MODE=hybrid
ORCHESTRATION_OAUTH_ISSUER=
ORCHESTRATION_OAUTH_AUDIENCE=
ORCHESTRATION_OAUTH_JWKS_URL=
ORCHESTRATION_OAUTH_REQUIRED_SCOPES=
ORCHESTRATION_OAUTH_JARVIS_USER_CLAIM=jarvis_user
ORCHESTRATION_OAUTH_DEFAULT_ALG=RS256
ORCHESTRATION_OAUTH_JWKS_TTL_S=300
ORCHESTRATION_OAUTH_JWKS_MIN_REFRESH_S=30
# App-level cockpit SSE refresh and heartbeat cadence.
ORCHESTRATION_SSE_REFRESH_INTERVAL_S=1.0
ORCHESTRATION_SSE_HEARTBEAT_INTERVAL_S=15.0
# Image attachment limits for cockpit turns (/turns and /work/start).
ORCHESTRATION_TURN_ATTACHMENT_MAX_COUNT=4
ORCHESTRATION_TURN_ATTACHMENT_MAX_BYTES=5242880

# Linear work source. Used by `jarvis work --source linear ...`.
LINEAR_API_KEY=

# --- Alarms & timers — fire on the device they're set on, repeat until acked ---
# `set_alarm` (gated by alarms.set). The sound + repeat cadence are config so they're
# easy to change: it rings for RING_S, pauses QUIET_S, and repeats until you say
# "stop" (or ALARM_MAX_S elapses as a safety net).
ALARM_ENABLED=true
ALARM_RING_S=10                      # ring this long each cycle
ALARM_QUIET_S=10                     # pause between rings
ALARM_MAX_S=300                      # auto-stop after this long unacknowledged
ALARM_SOUND=chime                    # tone name (generated) or a path to a sound file
ALARM_TONE_FREQ=880                  # generated-tone pitch (Hz) — tweak the sound

# --- Notification routing -------------------------------------------------
# A notification (background-job result, heartbeat) always goes to the user's
# device; with this on it ALSO goes to them on WhatsApp (to the number in their
# users/<name>.md), via the WhatsApp connector, so it reaches them when out.
NOTIFY_ALSO_WHATSAPP=false

# --- Browser lane — a real Chrome driven over CDP (nodriver, no Playwright) ---
# Hosted in the worker (the brain drives it over HTTP). Gated by worker.browser.
# Two device-scoped contexts: 'jarvis' (own headed, persistent profile — zero setup)
# and 'device' (the machine's default Chrome profile + its logins). Needs the
# `[browser]` extra (uv sync --extra browser) and Google Chrome installed.
BROWSER_ENABLED=true
BROWSER_DEFAULT_CONTEXT=jarvis        # context when unspecified: jarvis | device
BROWSER_HEADLESS=false               # headed by default (less detectable + you can take over)
BROWSER_CHROME_PATH=                 # explicit Chrome binary; blank => autodetect
BROWSER_JARVIS_PROFILE_DIR=jarvis-workspace/browser/jarvis-profile
BROWSER_DEVICE_PROFILE_DIR=          # the OS default Chrome profile dir (for the 'device' context)
BROWSER_NAV_TIMEOUT_S=30
BROWSER_REQUEST_TIMEOUT_S=45

# --- WhatsApp connector (Phase 3b) — wraps `wacli` ------------------------
# `jarvis whatsapp` bridges WhatsApp <-> brain. Needs wacli (wacli.sh) installed +
# linked (`wacli auth`). Poll model: it runs `wacli sync --follow` + polls new inbound.
WHATSAPP_ENABLED=false
WHATSAPP_WACLI_BIN=wacli
WHATSAPP_ACCOUNT=                    # wacli named account (optional; empty = default)
WHATSAPP_DEVICE_ID=whatsapp
WHATSAPP_TOKEN=                      # brain pairing token for this connector
WHATSAPP_POLL_INTERVAL_S=2
# Access control (deny-by-default, like OpenClaw's dmPolicy/allowFrom): who may message
# the bot. allowlist (only WHATSAPP_ALLOW_FROM + paired users) | pairing (allowlist, plus
# an unknown number can request admin-approved onboarding — see WHATSAPP_ADMIN) | open
# (anyone — unsafe) | disabled.
WHATSAPP_DM_POLICY=allowlist
WHATSAPP_ALLOW_FROM=                 # CSV of allowed E.164 numbers, e.g. 447921815819
# Remote pairing: an unknown DM-er gets a holding reply and YOU (the admin) get a
# "approve <code> <name>" prompt. Reply "approve <code> Alice" to create/merge
# users/alice.md (own memory + personal scope) and let them through; "deny <code>".
# Empty admin => no one can pair (unknown numbers are simply ignored). No auto-approve.
WHATSAPP_ADMIN=                      # the E.164 number allowed to approve pairings, e.g. 447921815819
WHATSAPP_TEXT_CHUNK_LIMIT=4000      # split long replies (WhatsApp length cap)
# Groups: ignore (never reply in groups) | mention (reply only when called out by the
# trigger name) | open (reply to every group message — noisy).
WHATSAPP_GROUP_POLICY=ignore
WHATSAPP_TRIGGER=jarvis             # the call-out word in groups ("Jarvis, …")
WHATSAPP_GROUP_ALLOW=               # CSV of allowed group JIDs (empty = any group)

# --- MCP bridge (Phase 3 §6) — gated tools from your MCP servers ----------
# The brain connects to each server at startup, discovers its tools, and offers
# them gated by `mcp.<name>` (grant that capability in a device profile / the CSV
# default to enable). Needs the extra: `uv sync --extra mcp`. Probe with
# `jarvis mcp`. Each server mirrors a Claude-Code mcpServers entry:
#   stdio: {"name","command","args",["env"],["capability"],["include"],["keywords"]}
#   http:  {"name","transport":"http","url",["headers"],["capability"],["scope"]}
# An http server with no "headers" uses OAuth — run `jarvis mcp login` once to
# authorize it in the browser (tokens cached; the brain refreshes them silently
# and never pops a browser on the voice path). An http server WITH static
# "headers" (e.g. an API key) skips OAuth. OAuth registers a public client + PKCE
# by default ("token_endpoint_auth_method":"none"); set that key per server to
# "client_secret_post"/"client_secret_basic" only if a server requires a secret.
MCP_ENABLED=false
# JSON array of servers. Example (a local stdio server + a remote OAuth one):
# MCP_SERVERS=[{"name":"context7","command":"npx","args":["-y","@upstash/context7-mcp"]},{"name":"notion","transport":"http","url":"https://mcp.notion.com/mcp"}]
MCP_SERVERS=[]
MCP_CALL_TIMEOUT_S=20                 # hard per-call bound (hot path never hangs)
MCP_CONNECT_TIMEOUT_S=20             # per-server connect/discovery bound (startup)
MCP_MAX_TOOLS_PER_SERVER=40          # firewall: cap tools any one server can add
MCP_NAMESPACE=true                   # offer tools as "<server>_<tool>"
MCP_AUTH_DIR=jarvis-workspace/.mcp-auth   # where OAuth tokens persist (gitignored)
MCP_OAUTH_REDIRECT_PORT=41760        # localhost port the `mcp login` browser flow uses

# --- MCP server (Jarvis as a server for external agents) ------------------
# `jarvis mcp-serve` exposes Jarvis brain powers over MCP. Hybrid mode accepts
# static per-principal tokens and spec OAuth JWT access tokens.
MCP_SERVE_HOST=localhost
MCP_SERVE_PORT=8795
# Empty => MCP_SERVE_HOST.
MCP_SERVE_BIND_HOST=
MCP_SERVE_TOKEN_STORE_PATH=jarvis-workspace/.mcp-server/tokens.json
MCP_SERVE_AUTH_MODE=hybrid           # legacy | oauth | hybrid
# Empty => http://MCP_SERVE_HOST:MCP_SERVE_PORT; changing invalidates outstanding OAuth access tokens (audience).
MCP_SERVE_RESOURCE_URL=
# Authorization server issuer URL.
MCP_SERVE_OAUTH_ISSUER=
# Authorization server JWKS endpoint.
MCP_SERVE_OAUTH_JWKS_URL=
# Optional CSV/space-separated required scopes.
