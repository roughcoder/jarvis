# Jarvis Phase 1 config — copy to .env and fill in secrets.
# HARD RULE (spec §3.1): all hosts/ports are env-driven; defaults are localhost.
# Phase 2 migration = change the *_HOST vars to a Tailscale hostname. Nothing else.

# --- LLM gateway (LiteLLM proxy) -----------------------------------------
GATEWAY_HOST=localhost
GATEWAY_PORT=4000
GATEWAY_API_KEY=sk-jarvis-local
GATEWAY_CLIENT_KEY=sk-jarvis-voice
GATEWAY_SPEAKER=family
GATEWAY_ROOM=default
GATEWAY_FAST_MODEL=fast
GATEWAY_STRONG_MODEL=strong

# Provider keys consumed by LiteLLM (NOT by the turn loop). At least one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HONCHO_LLM_KEY=sk-honcho-memory

# --- Memory (Honcho) ------------------------------------------------------
MEMORY_HOST=localhost
MEMORY_PORT=8000
MEMORY_API_KEY=
MEMORY_WORKSPACE_ID=jarvis
MEMORY_USER_PEER_ID=user
MEMORY_ASSISTANT_PEER_ID=jarvis
MEMORY_CACHE_PATH=.cache/representation.json

# --- Database (Postgres + pgvector, backs Honcho) -------------------------
DB_HOST=localhost
DB_PORT=5433
DB_USER=honcho
DB_PASSWORD=honcho
DB_NAME=honcho

# --- TTS (cloud streaming) ------------------------------------------------
# provider: inworld | smallest
TTS_PROVIDER=inworld
TTS_BASE_URL=https://api.inworld.ai
TTS_API_KEY=
TTS_VOICE=Ashley
TTS_MODEL_ID=inworld-tts-2
TTS_LANGUAGE=en-US

# --- STT (local Faster-Whisper) ------------------------------------------
STT_MODEL=distil-large-v3
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en

# --- VAD (Silero) — tunables (spec §8) -----------------------------------
VAD_ENDPOINT_SILENCE_MS=900
VAD_SPEECH_THRESHOLD=0.5
VAD_BARGEIN_ENABLED=true
VAD_BARGEIN_MODE=wakeword
VAD_BARGEIN_THRESHOLD=0.6
VAD_BARGEIN_MIN_MS=200
VAD_BARGEIN_GRACE_MS=250
VAD_MIN_SPEECH_MS=200
VAD_CONVERSATION_MODE=true
VAD_CONVERSATION_TIMEOUT_MS=8000

# --- Wake word (openWakeWord "hey_jarvis" | set WAKE_ENGINE=porcupine) ----
WAKE_ENGINE=openwakeword
WAKE_ACCESS_KEY=
WAKE_KEYWORD=hey_jarvis
WAKE_THRESHOLD=0.5
WAKE_KEYWORD_PATH=
WAKE_SENSITIVITY=0.5

# --- Audio ----------------------------------------------------------------
AUDIO_SAMPLE_RATE=16000
AUDIO_FRAME_MS=32
AUDIO_ACK_MODE=beep
AUDIO_ACK_PHRASE=Yes?

# --- Tracing (per-turn pipeline timings) ---------------------------------
TRACE_ENABLED=true
TRACE_PATH=.cache/traces.jsonl
TRACE_CONSOLE=true

# --- Persona (soul personality + shared conversation context) ------------
PERSONA_SOUL_PATH=SOUL.md
PERSONA_HISTORY_MESSAGES=16
