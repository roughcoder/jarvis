.ruff_cache/
models/*.ppn
*.egg-info/
dist/
build/

# Agent/harness state (not part of the project)
.omc/
.omx/

# peekaboo / screencapture debris
screen*.png

# browser lane runtime profiles (Chrome user-data dirs)
jarvis-workspace/browser/

# User principal files hold PII (phone numbers, personal scope) — keep them local
jarvis-workspace/users/*.md

# Local fleet/operator notes can contain hostnames, Tailscale IPs, phone numbers,
# private account choices, and setup history.
docs/private/
